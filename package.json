{
  "name": "loan-marketplace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "watchlib": "concurrently \"pnpm --filter commonlib watch\" \"pnpm --filter backendsdk watch\"",
    "buildlib": "pnpm --filter commonlib build && pnpm --filter backendsdk build",
    "build:backend": "pnpm --filter backend build",
    "build:frontend": "pnpm --filter frontend build",
    "format": "prettier --write --ignore-unknown ."
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  }
}
