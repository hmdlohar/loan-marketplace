# Public backend URL — used to build /api/files/* proxy URLs stored in DB
API_BASE_URL=http://localhost:4000

MONGODB_URL=mongodb://localhost:27017/loan-marketplace

# seedAdmin — first system admin user
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_MOBILE=

# seedImport — partner that owns imported products (banks + products from data/import-products.json)
# Bank logos are uploaded to S3; banks.LogoPath stores the key (e.g. public/lender-logos/{bankId}.svg)
# Frontend resolves display URL via {NEXT_PUBLIC_ROOT_URL}/api/files/{LogoPath}
SEED_PARTNER_ID=

# AWS S3 / S3-compatible storage (e.g. iDrive E2)
# AWS_S3_BUCKET = your bucket name (NOT the endpoint hostname)
# AWS_S3_ENDPOINT = custom endpoint URL for S3-compatible providers
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-bucket-name
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=true
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# MSG91 OTP Widget — send OTP in browser; verify OTP on server via widget API
# Auth key: widget → Server-Side Integration (optional legacy access-token path)
MSG91_AUTH_KEY=
MSG91_WIDGET_ID=
# Widget token: same as NEXT_PUBLIC_MSG91_WIDGET_TOKEN on frontend
MSG91_WIDGET_TOKEN=
# Local dev without MSG91 widget: set MSG91_OTP_DEV_MODE=true and use MSG91_OTP_DEV_CODE (default 123456)
MSG91_OTP_DEV_MODE=false
MSG91_OTP_DEV_CODE=123456

# OpenCode Zen — free models via https://opencode.ai/docs/zen/
ZEN_API_KEY=
LLM_DEFAULT_PROVIDER=opencode-zen
LLM_DEFAULT_MODEL=deepseek-v4-flash-free

# Optional future providers
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
