# Public backend URL — used to build /api/files/* proxy URLs stored in DB
API_BASE_URL=http://localhost:4000

MONGODB_URL=mongodb://localhost:27017/loan-marketplace

# seedAdmin — first system admin user
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_MOBILE=

# seedImport — partner that owns imported products (banks + products from data/import-products.json)
# Bank logos are uploaded to S3; banks.LogoPath stores the key (e.g. public/lender-logos/{bankId}.svg)
# Frontend resolves display URL via {NEXT_PUBLIC_ROOT_URL}/api/files/{LogoPath}
SEED_PARTNER_ID=

# AWS S3 / S3-compatible storage (e.g. iDrive E2)
# AWS_S3_BUCKET = your bucket name (NOT the endpoint hostname)
# AWS_S3_ENDPOINT = custom endpoint URL for S3-compatible providers
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-bucket-name
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=true
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# MSG91 OTP (https://docs.msg91.com/otp) — SendOTP + Verify OTP
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_OTP_EXPIRY_MINUTES=10
MSG91_OTP_LENGTH=6
# Local dev without MSG91: set MSG91_OTP_DEV_MODE=true and use MSG91_OTP_DEV_CODE (default 123456)
MSG91_OTP_DEV_MODE=false
MSG91_OTP_DEV_CODE=123456
