NEXT_PUBLIC_ROOT_URL=http://localhost:4000
NEXT_PUBLIC_IS_DEVELOPMENT=true

# MSG91 OTP Widget (OTP → your widget → Client integration → Web SDK custom UI)
# widgetId + widget token (NOT your account auth key)
NEXT_PUBLIC_MSG91_WIDGET_ID=
NEXT_PUBLIC_MSG91_WIDGET_TOKEN=
# Hide captcha mount + skip client checks (widget must also disable captcha in MSG91 dashboard)
NEXT_PUBLIC_MSG91_WIDGET_CAPTCHA=false
# Optional: force backend dev OTP flow (Mobile + fixed code) instead of widget
NEXT_PUBLIC_MSG91_OTP_DEV_MODE=false
